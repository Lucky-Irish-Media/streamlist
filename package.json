{
  "name": "streamlist",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-changelog.js",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare deploy",
    "deploy:prod": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && wrangler deploy --config wrangler.production.jsonc",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:push": "drizzle-kit push:sqlite"
  },
  "dependencies": {
    "@libsql/client": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "drizzle-orm": "^0.30.0",
    "esbuild": "^0.28.0",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.0.0",
    "next": "14.2.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.77.0"
  },
  "overrides": {
    "next": "14.2.15"
  }
}
